{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JFlow",
  "version": "0.1.0",
  "identifier": "ai.jflow.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "launcher",
        "title": "JFlow Launcher",
        "width": 720,
        "height": 420,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "acceptFirstMouse": true
      },
      {
        "label": "workbench",
        "title": "JFlow",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 400,
        "resizable": true,
        "visible": false,
        "acceptFirstMouse": true,
        "tabbingIdentifier": "JFlow",
        "decorations": false,
        "transparent": true
      },
      {
        "label": "pages",
        "title": "JFlow Settings",
        "width": 960,
        "height": 680,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "visible": false,
        "acceptFirstMouse": true,
        "tabbingIdentifier": "JFlow",
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/Applications/**",
          "/System/Applications/**",
          "/System/Library/CoreServices/Applications/**",
          "$HOME/Applications/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
